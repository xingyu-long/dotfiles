FROM mirror.gcr.io/library/ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Homebrew prerequisites for Linux
RUN apt-get update && apt-get install -y \
    build-essential \
    procps \
    curl \
    file \
    git \
    sudo \
    zsh \
    && rm -rf /var/lib/apt/lists/*

# Homebrew refuses to run as root; create a non-root user
RUN useradd -m -s /bin/zsh dotfiles && \
    echo 'dotfiles ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

USER dotfiles
WORKDIR /home/dotfiles

COPY --chown=dotfiles:dotfiles . /home/dotfiles/dotfiles

RUN cd /home/dotfiles/dotfiles && DOTFILES_OVERWRITE_ALL=true bash install.sh
